# PostgreSQL container bootstrap
POSTGRES_DB=agrafa
POSTGRES_USER=agrafa
POSTGRES_PASSWORD=change_me

# PostgreSQL
POSTGRES_URI=postgres://agrafa:change_me@postgres:5432/agrafa?sslmode=disable

# App
APP_ENV=development
PORT=8080
APP_BASE_URL=http://localhost:5173
APP_SECRET=replace_with_a_long_random_secret
NODE_HEARTBEAT_TTL_SECONDS=60
NODE_EXPIRY_CHECK_INTERVAL_SECONDS=15
MANAGED_SERVICE_CHECK_INTERVAL_SECONDS=15
MANAGED_SERVICE_CHECK_TIMEOUT_SECONDS=10
SESSION_TTL_DAYS=7
SESSION_REMEMBER_TTL_DAYS=30

# Frontend
VITE_API_URL=http://localhost:8080

# Container images
GHCR_OWNER=mariusbobitiu
AGRAFA_BACKEND_TAG=latest
AGRAFA_FRONTEND_TAG=latest

# Optional varables - any of these variables can be set via the UI
# If set here, these values override any matching settings configured in the UI/database.

# Resend
# EMAIL_ENABLED=false
# EMAIL_PROVIDER=resend
# EMAIL_RESEND_API_KEY=
# EMAIL_RESEND_DOMAIN=
