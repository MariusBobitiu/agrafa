# ------------------------------------------------------------------
# Container Images
# ------------------------------------------------------------------
GHCR_OWNER=your-github-user

# ------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------
POSTGRES_DB=agrafa
POSTGRES_USER=agrafa
POSTGRES_PASSWORD=change_me

POSTGRES_URI=postgres://agrafa:change_me@postgres:5432/agrafa?sslmode=disable
POSTGRES_MIGRATIONS_SCHEMA=agrafa_meta
POSTGRES_MIGRATIONS_TABLE=schema_migrations

# ------------------------------------------------------------------
# App
# ------------------------------------------------------------------
APP_ENV=production
PORT=8080

# Base URL of the frontend (used for links, CORS, etc.)
# IP mode example: http://server_ip:8080
# Domain mode example: https://agrafa.example.com
APP_BASE_URL=http://localhost:8080

# Allowed origins for frontend requests
APP_ALLOWED_ORIGINS=http://localhost:8080

# Generate with: openssl rand -base64 48
APP_SECRET=replace_with_secure_random_value

# ------------------------------------------------------------------
# Runtime tuning
# ------------------------------------------------------------------
NODE_HEARTBEAT_TTL_SECONDS=60
NODE_EXPIRY_CHECK_INTERVAL_SECONDS=15
MANAGED_SERVICE_CHECK_INTERVAL_SECONDS=15
MANAGED_SERVICE_CHECK_TIMEOUT_SECONDS=10
SESSION_TTL_DAYS=7
SESSION_REMEMBER_TTL_DAYS=30

# ------------------------------------------------------------------
# Install mode (controlled by install.sh)
# ------------------------------------------------------------------

# Set to "true" when using a domain (enables Traefik routing)
TRAEFIK_ENABLED=false

# Domain name (only used if TRAEFIK_ENABLED=true)
DOMAIN=localhost

# Email for Let's Encrypt (only used if TRAEFIK_ENABLED=true)
LETSENCRYPT_EMAIL=

# Ports exposed on host (IP mode)
FRONTEND_HOST_PORT=8080
BACKEND_HOST_PORT=8081

# Docker Compose profile (set to "domain" when using domain mode)
COMPOSE_PROFILES=

# ------------------------------------------------------------------
# Email (optional)
# ------------------------------------------------------------------
EMAIL_ENABLED=false
EMAIL_PROVIDER=resend
EMAIL_RESEND_API_KEY=
EMAIL_RESEND_DOMAIN=