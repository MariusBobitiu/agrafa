# --------------------------------------------------------------------
# Environment variables for the agent
# --------------------------------------------------------------------
AGRAFA_API_BASE_URL=http://localhost:8080/v1
AGRAFA_AGENT_TOKEN=replace-with-node-agent-token
AGRAFA_NODE_ID=1
AGRAFA_SOURCE=agent
AGRAFA_API_TIMEOUT_SECONDS=10
AGRAFA_API_RETRY_COUNT=1

# --------------------------------------------------------------------
# Intervals (in seconds)
# --------------------------------------------------------------------
AGRAFA_HEARTBEAT_INTERVAL_SECONDS=15
AGRAFA_METRICS_INTERVAL_SECONDS=15
AGRAFA_HEALTH_INTERVAL_SECONDS=30
AGRAFA_CONFIG_REFRESH_SECONDS=30
# Default timeout for outbound HTTP health checks
AGRAFA_HTTP_TIMEOUT_SECONDS=10

# --------------------------------------------------------------------
# Paths
# --------------------------------------------------------------------
AGRAFA_DISK_PATH=/
# Optional fallback/dev-only checks file used if backend config is unavailable
AGRAFA_HEALTH_CHECKS_FILE=./health_checks.json

# --------------------------------------------------------------------
# Additional environment variables can be added below as needed
# --------------------------------------------------------------------
