# --------------------------------------------------------------------
# PostgreSQL
# --------------------------------------------------------------------
POSTGRES_URI=postgres://username:password@localhost:5432/agrafa

# --------------------------------------------------------------------
# App
# --------------------------------------------------------------------
APP_ENV=development # Set to 'production' in production environment
PORT=8080 # Port for the backend server
APP_BASE_URL=http://localhost:3000 # Frontend URL, used for CORS and email links
APP_SECRET=replace_with_a_long_random_secret # e.g. openssl rand -base64 32

# --------------------------------------------------------------------
# Runtime tuning
# --------------------------------------------------------------------
NODE_HEARTBEAT_TTL_SECONDS=60 # Time in seconds after which a node is considered inactive if no heartbeat is received
NODE_EXPIRY_CHECK_INTERVAL_SECONDS=15 # Time in seconds between checks for expired nodes and sessions
SESSION_TTL_DAYS=7 # Time in days after which a session expires
SESSION_REMEMBER_TTL_DAYS=30 # Time in days after which a "remember me" session expires

# --------------------------------------------------------------------
# Resend (optional)
# --------------------------------------------------------------------
EMAIL_ENABLED=false # Set to true to enable email functionality
EMAIL_PROVIDER=resend # Email service provider (e.g. 'resend')
EMAIL_RESEND_API_KEY=replace_with_your_resend_api_key # API key for Resend email service
EMAIL_RESEND_DOMAIN=replace_with_your_resend_domain	# Domain for sending emails with Resend (e.g. 'email.yourdomain.com')