# PostgreSQL
POSTGRES_URI=postgres://username:password@localhost:5432/agrafa

# App
APP_ENV=development
PORT=8080
APP_BASE_URL=http://localhost:5173
APP_SECRET=replace_with_a_long_random_secret

# Runtime tuning
NODE_HEARTBEAT_TTL_SECONDS=60
NODE_EXPIRY_CHECK_INTERVAL_SECONDS=15
SESSION_TTL_DAYS=7
SESSION_REMEMBER_TTL_DAYS=30

# Optional varables - any of these variables can be set via the UI
# Setting those variables here will override the values set via the UI, which can be useful for development and testing purposes 

# Resend
# EMAIL_ENABLED=false
# EMAIL_PROVIDER=resend
# EMAIL_RESEND_API_KEY=replace_with_your_resend_api_key
# EMAIL_RESEND_DOMAIN=replace_with_your_resend_domain