# --------------------------------------------------------------------
# PostgreSQL
# --------------------------------------------------------------------
# Single PostgreSQL database for Agrafa.
# Application tables live in the `app` schema.
# The `auth` schema is reserved for auth-specific tables.
POSTGRES_URI=postgres://username:password@localhost:5432/agrafa
POSTGRES_MIGRATIONS_SCHEMA=agrafa_meta
POSTGRES_MIGRATIONS_TABLE=schema_migrations

# --------------------------------------------------------------------
# App
# --------------------------------------------------------------------
APP_ENV=development
PORT=8080
APP_BASE_URL=http://localhost:3000
NODE_HEARTBEAT_TTL_SECONDS=60
NODE_EXPIRY_CHECK_INTERVAL_SECONDS=15
SESSION_TTL_DAYS=7
SESSION_REMEMBER_TTL_DAYS=30

# --------------------------------------------------------------------
# Resend
# --------------------------------------------------------------------
RESEND_API_KEY=your_resend_api_key
RESEND_EMAIL_DOMAIN=your_resend_email_domain
ALERTS_FROM_EMAIL=alerts@your_resend_email_domain
